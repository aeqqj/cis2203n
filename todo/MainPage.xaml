<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="todo.MainPage"
             BackgroundColor="#101010"
             Title="todo">

    <VerticalStackLayout Spacing="10" VerticalOptions="FillAndExpand" HorizontalOptions="Fill">
        <VerticalStackLayout Padding="10" Spacing="10" BackgroundColor="#101010" Margin="0,0,0,10">
            <Entry x:Name="titleEntry"
                   Placeholder="Title"
                   PlaceholderColor="#666666"
                   TextColor="#FFFFFF"
                   BackgroundColor="#101010"
                   Keyboard="Text" ReturnType="Next" MaxLength="50"/>
            <Editor x:Name="detailsEditor"
                    Placeholder="Details"
                    PlaceholderColor="#666666"
                    TextColor="#FFFFFF"
                    BackgroundColor="#101010"
                    MaxLength="240" Keyboard="Text" HeightRequest="100"/>
            <Button x:Name="addBtn" IsVisible="True"
                    Text="Add"
                    TextColor="#FFFFFF"
                    BackgroundColor="#2a2a2a"
                    Clicked="AddToDoItem"/>
            <Button x:Name="editBtn" IsVisible="False"
                    Text="Edit"
                    TextColor="#FFFFFF"
                    BackgroundColor="#2A2A2A"
                    Clicked="EditToDoItem"/>
            <Button x:Name="cancelBtn" IsVisible="False"
                    Text="Cancel Edit"
                    TextColor="#FFFFFF"
                    BackgroundColor="#ff6467"
                    Clicked="CancelEdit"/>
        </VerticalStackLayout>

        <ListView x:Name="todoLV"
                  HorizontalOptions="Fill" VerticalOptions="FillAndExpand"
                  HasUnevenRows="True" SeparatorVisibility="Default"
                  BackgroundColor="#101010"
                  ItemSelected="TodoLV_OnItemSelected"
                  ItemTapped="todoLV_ItemTapped">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <ViewCell>
                        <Grid VerticalOptions="FillAndExpand" RowSpacing="5"
                              HorizontalOptions="FillAndExpand" Margin="20"
                              BackgroundColor="#101010">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="8*"/>
                                <ColumnDefinition Width="2*"/>
                            </Grid.ColumnDefinitions>

                            <Label Grid.Row="0" Grid.Column="0"
                                   Text="{Binding title}"
                                   TextColor="#FFFFFF"
                                   LineBreakMode="TailTruncation" FontSize="16"
                                   VerticalOptions="Center" HorizontalOptions="Start"/>
                            <Label Grid.Row="1" Grid.Column="0"
                                   Text="{Binding detail}"
                                   TextColor="#AAAAAA"
                                   LineBreakMode="TailTruncation" FontSize="14"
                                   VerticalOptions="Center" HorizontalOptions="Start"/>
                            <Button Text="Delete"
                                    BackgroundColor="#ff6467"
                                    TextColor="#FFFFFF"
                                    ClassId="{Binding id}"
                                    Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
                                    Clicked="DeleteToDoItem"/>
                        </Grid>
                    </ViewCell>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </VerticalStackLayout>

</ContentPage>
